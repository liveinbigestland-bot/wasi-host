# Key material (sensitive)
p2p_key*.bin

# Planning files (development only)
.planning/

# Graphify knowledge graph (auto-generated)
graphify-out/

# Spec work (development only)
openspec/

# OS files
.DS_Store
Thumbs.db

# Claude Code local settings (user-specific)
.claude/


# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

zig-out/
zig-*/
zig-cache-tmp/
.zig-cache/
zig-cache/
*.o
*.obj
zig-bin

# Runtime artifacts
api_response.txt

# Downloaded toolchains
zig-linux-*/
zig-linux-*.tar.xz

# Python
__pycache__/
*.pyc

# Debug symbols (Windows)
*.pdb

# Log files
*.log

